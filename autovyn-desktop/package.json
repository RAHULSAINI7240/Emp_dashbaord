{
  "name": "autovyn-desktop",
  "version": "0.1.0",
  "description": "Installable Autovyn desktop app for employee time tracking.",
  "main": "src/main.js",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node scripts/check-syntax.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg --x64 --arm64",
    "dist:mac:universal": "electron-builder --mac dmg --universal",
    "dist:windows": "electron-builder --win nsis --x64",
    "dist:linux": "electron-builder --linux deb AppImage",
    "dist:linux:appimage": "electron-builder --linux AppImage",
    "publish:installers": "node scripts/publish-installers.js",
    "dist:publish": "npm run dist && npm run publish:installers"
  },
  "engines": {
    "node": ">=18.19"
  },
  "homepage": "https://autovyn.local",
  "author": {
    "name": "Autovyn Engineering",
    "email": "engineering@autovyn.local"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.autovyn.agent",
    "productName": "Autovyn Desktop",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "Autovyn-Desktop-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal",
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "Autovyn-Desktop-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "gatekeeperAssess": false,
      "hardenedRuntime": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Autovyn Engineering <engineering@autovyn.local>",
      "icon": "assets/icon.png",
      "artifactName": "Autovyn-Desktop.${ext}",
      "category": "Office",
      "executableArgs": [
        "--no-sandbox",
        "--ozone-platform=x11"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
